# Slack bot token (xoxb-...). Create an INTERNAL (single-workspace, non-distributed)
# app so conversations/files APIs keep the old rate limits.
SLACK_BOT_TOKEN=xoxb-your-token

# Channel name (without '#') or channel ID.
SLACK_CHANNEL=general

# Google auth uses Application Default Credentials (ADC) from gcloud — no key
# file here. Before running, authorize once as yourself:
#   gcloud auth application-default login \
#     --scopes=openid,https://www.googleapis.com/auth/drive

# Destination folder ID. Can be a personal My Drive folder or a Shared Drive
# folder. It's the last path segment of the folder URL:
# https://drive.google.com/drive/folders/<THIS_ID>
DRIVE_FOLDER_ID=your-folder-id

# Optional overrides.
# DOWNLOAD_DIR=./downloads
# MANIFEST_PATH=./manifest.json
